{
  "name": "invoice-app",
  "private": true,
  "version": "1.0.0",
  "description": "Professional Invoice Management App",
  "author": "Your Name",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "next build && node scripts/prepare-electron-standalone.mjs && electron-builder",
    "electron:build:win": "next build && node scripts/prepare-electron-standalone.mjs && electron-builder --win",
    "electron:build:mac": "next build && node scripts/prepare-electron-standalone.mjs && electron-builder --mac",
    "electron:build:linux": "next build && node scripts/prepare-electron-standalone.mjs && electron-builder --linux",
    "export": "next build"
  },
  "build": {
    "appId": "com.invoiceapp.desktop",
    "productName": "Helferlein",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      ".next/standalone/**/*",
      ".next/static/**/*",
      "public/**/*",
      "package.json"
    ],
    "extraResources": [],
    "asar": false,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "public/icon.icns",
      "category": "public.app-category.business"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "public/icon.png",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-store": "^11.0.2",
    "lucide-react": "^0.562.0",
    "next": "16.1.1",
    "ogl": "^1.0.11",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "shadcn": "^3.6.2",
    "tailwind-merge": "^3.4.0",
    "three": "^0.167.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.18",
    "@types/node": "22.13.11",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@types/three": "^0.182.0",
    "autoprefixer": "10.4.23",
    "concurrently": "^9.2.1",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "eslint": "9.36.0",
    "eslint-config-next": "16.1.1",
    "png-to-ico": "^3.0.1",
    "postcss": "8.5.6",
    "tailwindcss": "4.1.18",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.2",
    "wait-on": "^9.0.3"
  }
}
